{
    "serviceTypes": {
        "systemd": {
            "enabled": true,
            "group": "systemServices"
        },
        "head": {
            "enabled": true,
            "interval": 60000,
            "group": "websites"
        },
        "ping": {
            "enabled": true,
            "group": "networkChecks"
        },
        "nginx": {
            "enabled": true,
            "path": "/etc/nginx/sites-enabled",
            "group": "websites"
        },
        "storageVolume": {
            "enabled": true,
            "interval": 360000,
            "group": "storage"
        },
        "connectivityCheck": {
            "enabled": true
        }
    },
    "groups": {
        "networkChecks": {
            "name": "Network Checks",
            "checkbox": true,
            "showLastChecked": true
        },
        "websites": {
            "name": "Websites",
            "checkbox": true,
            "showLastChecked": true
        },
        "storage": {
            "name": "Storage Volumes",
            "checkbox": true,
            "showLastChecked": true
        },
        "systemServices": {
            "name": "System Services",
            "checkbox": true,
            "showLastChecked": true
        }
    },
    "services": [
        {
            "name": "File Server",
            "type": "systemd",
            "key": "smbd"
        },
        {
            "name": "Mongo DB",
            "type": "systemd",
            "key": "mongod"
        },
        {
            "name": "Remote Ctrl Forwarder",
            "type": "systemd",
            "key": "remoteCtrlForwarder"
        },
        {
            "name": "DNS Server",
            "type": "systemd",
            "key": "named"
        },
        {
            "name": "Jowe.ca",
            "type": "head",
            "key": "https://jowe.ca"
        },
        {
            "name": "Main RAID Storage",
            "type": "storageVolume",
            "key": "/dev/md0",
            "options": {
                "raid": true
            }
        },
        {
            "name": "Root Storage",
            "type": "storageVolume",
            "key": "/"
        },
        {
            "name": "Google DNS",
            "type": "ping",
            "key": "8.8.8.8",
            "card": false,
            "useForConnectivityCheck": true
        },
        {
            "name": "Cloudflare DNS",
            "type": "ping",
            "key": "1.1.1.1",
            "card": false,
            "useForConnectivityCheck": true
        },
        {
            "name": "Quad9",
            "type": "ping",
            "key": "8.8.8.8",
            "card": false,
            "useForConnectivityCheck": true
        }
    ],
    "headerData": [
        {
            "name": "Woodstove",
            "url": "http://iot.wnet.wn/automation_api/logical-device/iot.recroom_01.woodstove/data",
            "jsonKey": "woodstoveState",
            "formattingFunction": "formatWoodstoveState"
        },
        {
            "name": "Woodshed",
            "url": "http://iot.wnet.wn/automation_api/logical-device/iot.woodshed_01.batteryMonitor/data",
            "jsonKey": "voltageRaw",
            "formattingFunction": "formatLeadAcidBatteryVoltage"
        },
        {
            "name": "Outside",
            "url": "http://iot.wnet.wn/automation_api/logical-device/iot.woodshed_01.tempOutside/data",
            "jsonKey": "tempC",
            "formattingFunction": "formatTemperature"
        }
    ]
}