{
    "settings": {
        "pageTitle": "Status Hub - 5 Williston Ct"
    },
    "serviceTypes": {
        "systemd": {
            "enabled": true,
            "group": "systemServices"
        },
        "head": {
            "enabled": true,
            "interval": 60000,
            "group": "websites"
        },
        "ping": {
            "enabled": true,
            "group": "networkChecks"
        },
        "nginx": {
            "enabled": true,
            "path": "/etc/nginx/sites-enabled",
            "group": "websites"
        },
        "storageVolume": {
            "enabled": true,
            "interval": 360000,
            "group": "storage"
        },
        "connectivityCheck": {
            "enabled": true
        }
    },
    "groups": {
        "networkChecks": {
            "name": "Network Checks",
            "checkbox": true,
            "showLastChecked": true
        },
        "websites": {
            "name": "Websites",
            "checkbox": true,
            "showLastChecked": true
        },
        "storage": {
            "name": "Storage Volumes",
            "checkbox": true,
            "showLastChecked": true
        },
        "systemServices": {
            "name": "System Services",
            "checkbox": true,
            "showLastChecked": true
        }
    },
    "services": [
        {
            "name": "DHCP Server",
            "type": "systemd",
            "key": "isc-dhcp-server"
        },
        {
            "name": "File Server",
            "type": "systemd",
            "key": "smbd"
        },
        {
            "name": "Mongo DB",
            "type": "systemd",
            "key": "mongod"
        },
        {
            "name": "Remote Ctrl Forwarder",
            "type": "systemd",
            "key": "remoteCtrlForwarder"
        },
        {
            "name": "DNS Server",
            "type": "systemd",
            "key": "named"
        },
        {
            "name": "Jowe.ca",
            "type": "head",
            "key": "https://jowe.ca"
        },
        {
            "name": "Main RAID Storage",
            "type": "storageVolume",
            "key": "/dev/md0",
            "options": {
                "raid": true
            }
        },
        {
            "name": "Root Storage",
            "type": "storageVolume",
            "key": "/"
        },
        {
            "name": "Google DNS",
            "type": "ping",
            "key": "8.8.8.8",
            "card": false,
            "useForConnectivityCheck": true
        },
        {
            "name": "Cloudflare DNS",
            "type": "ping",
            "key": "1.1.1.1",
            "card": false,
            "useForConnectivityCheck": true
        },
        {
            "name": "Quad9",
            "type": "ping",
            "key": "8.8.8.8",
            "card": false,
            "useForConnectivityCheck": true
        }
    ],
    "headerData": [
        {
            "name": "Furnace",
            "dataUrl": "http://iot.wnet.wn/automation_api/logical-device/iot.furnace_closet_01.furnace/data",
            "jsonKey": "isOn",
            "formattingFunction": "formatFurnaceState",
            "url": "http://iot.wn/graph_all.html?deviceId=aggregates&timeframe=24h&accuracy=raw&interpolation=linear&fields=aggregates%3Adata.Sensor.aggregateTemp.spatialAverageInsideRolling.tempC%2Cfurnace_closet_01%3Adata.DeviceControl.Relay.furnace.isOn"
        },
        {
            "name": "Woodstove",
            "dataUrl": "http://iot.wnet.wn/automation_api/logical-device/iot.recroom_01.woodstove/data",
            "jsonKey": "woodstoveState",
            "formattingFunction": "formatWoodstoveState",
            "url": "http://iot.wn/graph_all.html?deviceId=aggregates&timeframe=12h&accuracy=raw&interpolation=linear&fields=aggregates%3Adata.Sensor.aggregateTemp.spatialAverageInsideRolling.tempC%2Cfurnace_closet_01%3Adata.DeviceControl.Relay.furnace.isOn%2Crecroom_01%3Adata.Sensor.DS18B20.woodstove.tempC%2Crecroom_01%3Adata.Sensor.DS18B20.woodstove.woodstoveState",
            "setPageTitle": {
                "jsonKey": "woodstoveState",
                "equals": "refuel",
                "pageTitleOverride": "REFUEL the Woodstove!",
                "triggerGlobalStatus": "alert"
            }
        },
        {
            "name": "Woodshed",
            "dataUrl": "http://iot.wnet.wn/automation_api/logical-device/iot.woodshed_01.batteryMonitor/data",
            "jsonKey": "voltageRaw",
            "formattingFunction": "formatLeadAcidBatteryVoltage",
            "url": "http://iot.wn/graph.html?deviceId=woodshed_01&fields=data.System.BatteryMonitor.batteryMonitor.netCharge_Wh%2Cdata.System.BatteryMonitor.batteryMonitor.voltageRaw&timeframe=7d&accuracy=raw&interpolation=linear"
        },
        {
            "name": "Outside",
            "dataUrl": "http://iot.wnet.wn/automation_api/logical-device/iot.woodshed_01.tempOutside/data",
            "jsonKey": "tempC",
            "formattingFunction": "formatTemperature",
            "url": "http://iot.wn/graph.html?deviceId=woodshed_01&fields=data.Sensor.DS18B20.tempOutside.tempC&timeframe=24h&accuracy=raw&interpolation=linear"
        },
        {
            "name": "Inside",
            "dataUrl": "http://iot.wnet.wn/automation_api/logical-device/iot.aggregates.spatialAverageInside/data",
            "jsonKey": "tempC",
            "formattingFunction": "formatTemperature",
            "url": "http://iot.wn/graph_all.html?deviceId=aggregates&timeframe=24h&accuracy=raw&interpolation=linear&fields=aggregates%3Adata.Sensor.aggregateTemp.spatialAverageInsideRolling.tempC%2Cfurnace_closet_01%3Adata.Sensor.DS18B20.recroom.tempC%2Ckitchen_01%3Adata.Sensor.DS18B20.tempKitchen.tempC%2ClaundryRoom_legacy%3Adata.Sensor.DS18B20.laundryRoom.tempC%2Clivingroom_01%3Adata.Sensor.SHT31.shtSensor.tempC%2Coffice_johannes_01%3Adata.Sensor.SHT31.shtSensor.tempC%2Cwoodshed_01%3Adata.Sensor.DS18B20.tempOutside.tempC"
        },
        {
            "name": "Internet",
            "headerKey": "connectivity"
        },
        {
            "name": "Status",
            "headerKey": "statusSummary",
            "setPageTitle": true
        }
    ]
}